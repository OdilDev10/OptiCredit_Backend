# ==================== DATABASE ====================
DATABASE_URL=postgresql+asyncpg://odil:password@localhost:5432/kashap

# ==================== SECURITY ====================
SECRET_KEY=kashap-dev-secret-key-change-in-production-2026
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== ENVIRONMENT ====================
ENVIRONMENT=development
APP_URL=http://localhost:8000

# ==================== EMAIL (SMTP) ====================
SMTP_EMAIL=noreply@kashap.local
SMTP_PASSWORD=

# ==================== SMS (TWILIO) ====================
SMS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ==================== BRAINTREE (PAYMENTS) ====================
BRAINTREE_MERCHANT_ID=
BRAINTREE_PUBLIC_KEY=
BRAINTREE_PRIVATE_KEY=

# ==================== STORAGE ====================
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./uploads

# ==================== CLOUDFLARE R2 ====================
# Only needed if STORAGE_BACKEND=r2
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kashap-uploads

# ==================== OCR (PADDLEOCR) ====================
OCR_ENABLED=true
OCR_DEVICE=cpu
OCR_USE_ANGLE_CLS=true
OCR_LANG=es

# ==================== API ====================
API_TITLE=Kashap - Plataforma de Préstamos
API_VERSION=0.1.0
API_DESCRIPTION=SaaS para gestión de préstamos con validación OCR
